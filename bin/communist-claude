#!/bin/bash

# Resolve the absolute path of the wrapper script
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
BINARY_PATH="$SCRIPT_DIR/../free-code-source/cli-dev"

if [[ ! -f "$BINARY_PATH" ]]; then
    echo "Error: The communist-claude binary has not been built."
    echo "Please run the ./install.sh script in the parent directory first."
    exit 1
fi

if [[ "$1" == "--minimax" ]]; then
    echo "☭ Routing to MiniMax API (95% cheaper, Opus-level performance)..."
    export ANTHROPIC_BASE_URL="https://api.minimaxi.com/anthropic"
    
    # If the user hasn't set MINIMAX_API_KEY in their environment, prompt them to edit the script or set it
    if [ -z "$MINIMAX_API_KEY" ]; then
        echo -e "\033[0;31mWarning: MINIMAX_API_KEY is not set.\033[0m"
        echo "Using placeholder key. Please 'export MINIMAX_API_KEY=\"sk-...\"' before running."
        export ANTHROPIC_API_KEY="sk-your-minimax-api-key"
    else
        export ANTHROPIC_API_KEY="$MINIMAX_API_KEY"
    fi

    export ANTHROPIC_MODEL="MiniMax-M2.7-highspeed"
    export ANTHROPIC_DEFAULT_OPUS_MODEL="MiniMax-M2.7-highspeed"
    export ANTHROPIC_DEFAULT_SONNET_MODEL="MiniMax-M2.7-highspeed"
    export ANTHROPIC_DEFAULT_HAIKU_MODEL="MiniMax-M2.7-highspeed"
    shift # Remove the --minimax flag from arguments passed to the binary
fi

# Execute the patched binary
exec "$BINARY_PATH" "$@"